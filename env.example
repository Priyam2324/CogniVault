# =============================================================================
# CogniVault - Environment Configuration Template
# Copy this file to ".env" and fill in the values marked "CHANGE ME" below.
# Never commit your real ".env" file to GitHub - only this .env.example.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE LLM ROUTING
# -----------------------------------------------------------------------------
# LLM_MODEL follows litellm's "<provider>/<model>" naming convention.
# Examples: "groq/llama-3.3-70b-versatile", "openai/gpt-4o-mini", "anthropic/claude-sonnet-4-5"
# See https://docs.litellm.ai/docs/providers for the full list of supported providers/models.
LLM_MODEL="groq/meta-llama/llama-4-scout-17b-16e-instruct"        # CHANGE ME: pick your provider/model
LLM_API_KEY="your-llm-api-key-here"                                # CHANGE ME: your own API key (get a new one - do not reuse an old exposed key)

# Only set this if you're pointing at a custom/self-hosted OpenAI-compatible endpoint.
# Leave blank/commented for standard providers like Groq, OpenAI, Anthropic, etc.
# LLM_ENDPOINT="https://your-custom-endpoint.example.com/v1"

COGNEE_SKIP_CONNECTION_TEST=true

# -----------------------------------------------------------------------------
# LOCAL CPU EMBEDDINGS (Fastembed)
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS=384

# -----------------------------------------------------------------------------
# DATA / SYSTEM DIRECTORIES (cognee storage locations)
# -----------------------------------------------------------------------------
# These are absolute paths used by cognee to store processed data + system files.
# CHANGE ME: replace with real paths that exist on YOUR machine.
# Windows example: "C:/Users/<you>/Documents/CogniVault/data"
# macOS/Linux example: "/home/<you>/cognivault/data"
DATA_ROOT_DIRECTORY="/absolute/path/to/clean_data"      # CHANGE ME
SYSTEM_ROOT_DIRECTORY="/absolute/path/to/clean_system"  # CHANGE ME

DB_PROVIDER="sqlite"
DB_NAME=cognee_db
VECTOR_DB_PROVIDER="lancedb"
GRAPH_DATABASE_PROVIDER="kuzu"

# -----------------------------------------------------------------------------
# SYSTEM / INFRASTRUCTURE FLAGS
# -----------------------------------------------------------------------------
REQUIRE_AUTHENTICATION=False
ENABLE_BACKEND_ACCESS_CONTROL=False
LITELLM_LOG="ERROR"
LITELLM_DROP_PARAMS=true

# -----------------------------------------------------------------------------
# OPTIONAL TUNING (all have safe defaults in main.py if omitted)
# -----------------------------------------------------------------------------
# CHUNK_SIZE=6000
# CHUNK_STORE_DELAY_SECONDS=1.0
# UPLOAD_CONTEXT_CHAR_BUDGET=40000
# COGNEE_DIR="./cognee_data"
